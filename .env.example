# ============================================================
# Superwave Agent — Environment Variables
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in the required values
# 3. Never commit .env
# ============================================================

# Database
POSTGRES_USER=superwave
POSTGRES_PASSWORD=
POSTGRES_DB=superwave

# LLM (OpenRouter)
OPENROUTER_API_KEY=

# ManyChat bridge
MANYCHAT_API_KEY=
SUPERWAVE_WEBHOOK_SECRET=
BRIDGE_SECRET=
ADMIN_SECRET=
MANYCHAT_ACK_TEXT=Gracias por tu mensaje. Un asesor revisará tu caso y te responderá en breve.
AGENT_ANALYSIS_TIMEOUT_MS=18000
BRIDGE_DRY_RUN=false

# Telegram review queue (approval workflow)
TELEGRAM_BOT_TOKEN=
TELEGRAM_REVIEW_CHAT_ID=
TELEGRAM_WEBHOOK_PATH_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_AGENT_ASSIST_ENABLED=true
TELEGRAM_AGENT_ASSIST_TIMEOUT_MS=25000

# Kanban destination (workspace object API)
KANBAN_API_BASE_URL=http://web:3100
KANBAN_OBJECT_NAME=task
KANBAN_DEFAULT_STATUS=In Queue

# Dashboard login (apps/web)
DASHBOARD_AUTH_SECRET=
DASHBOARD_ADMIN_EMAIL=admin@superwave.ai
DASHBOARD_ADMIN_PASSWORD=
DASHBOARD_ADMIN_NAME=Admin
# Optional advanced mode:
# DASHBOARD_USERS_JSON=[{"email":"admin@superwave.ai","passwordHash":"<sha256-hex>","name":"Admin","role":"admin"}]
