# ============================================================
# Superwave Agent — Environment Variables
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in the required values
# 3. Never commit .env
# ============================================================

# Database
POSTGRES_USER=superwave
POSTGRES_PASSWORD=
POSTGRES_DB=superwave

# LLM (OpenRouter)
OPENROUTER_API_KEY=

# ManyChat bridge
MANYCHAT_API_KEY=
SUPERWAVE_WEBHOOK_SECRET=
BRIDGE_SECRET=
ADMIN_SECRET=

# Dashboard login (apps/web)
DASHBOARD_AUTH_SECRET=
DASHBOARD_ADMIN_EMAIL=admin@superwave.ai
DASHBOARD_ADMIN_PASSWORD=
DASHBOARD_ADMIN_NAME=Admin
# Optional advanced mode:
# DASHBOARD_USERS_JSON=[{"email":"admin@superwave.ai","passwordHash":"<sha256-hex>","name":"Admin","role":"admin"}]
