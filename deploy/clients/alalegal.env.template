# ===================================================================
# ALA Legal deployment env template
# Domain: alalegal.proyectoprisma.com
# ===================================================================

CLIENT_SLUG=alalegal

# Unique host ports (avoid collisions with other clients on same host)
AGENT_GATEWAY_PORT=3011
BRIDGE_PUBLIC_PORT=4011
WEB_PUBLIC_PORT=3111

# Database
POSTGRES_USER=superwave
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=superwave_alalegal

# LLM
OPENROUTER_API_KEY=CHANGE_ME_OPENROUTER_KEY

# Bridge auth
SUPERWAVE_WEBHOOK_SECRET=CHANGE_ME_SUPERWAVE_WEBHOOK_SECRET
BRIDGE_SECRET=CHANGE_ME_BRIDGE_SECRET
ADMIN_SECRET=CHANGE_ME_ADMIN_SECRET

# ManyChat
MANYCHAT_API_KEY=Bearer CHANGE_ME_MANYCHAT_API_KEY
MANYCHAT_ACK_TEXT=Gracias por tu mensaje. Un asesor revisará tu caso y te responderá en breve.
AGENT_ANALYSIS_TIMEOUT_MS=18000
BRIDGE_DRY_RUN=false

# Telegram review + assist
TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN
TELEGRAM_REVIEW_CHAT_ID=CHANGE_ME_CHAT_ID
TELEGRAM_WEBHOOK_PATH_TOKEN=CHANGE_ME_RANDOM_PATH_TOKEN
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_RANDOM_SECRET
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_AGENT_ASSIST_ENABLED=true
TELEGRAM_AGENT_ASSIST_TIMEOUT_MS=25000

# Kanban lead destination
KANBAN_API_BASE_URL=http://web:3100
KANBAN_OBJECT_NAME=lead
KANBAN_DEFAULT_STATUS=In Queue
KANBAN_STAGE_NEW=In Queue
KANBAN_STAGE_QUALIFIED=In Progress
KANBAN_STAGE_ARCHIVE=Done
FIT_SCORE_HIGH=0.75
FIT_SCORE_LOW=0.35

# Dashboard auth
DASHBOARD_AUTH_SECRET=CHANGE_ME_DASHBOARD_AUTH_SECRET
DASHBOARD_ADMIN_EMAIL=admin@alalegal.proyectoprisma.com
DASHBOARD_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
DASHBOARD_ADMIN_NAME=ALA Legal Admin
